\n\t\t\t\t\tbackground-color: #e8f5e9;\n\t\t\t\t\tborder-radius: 6px;\n\t\t\t\t}\n\t\t\t\t.amount-label {\n\t\t\t\t\tfont-size: 14px;\n\t\t\t\t\tcolor: #7f8c8d;\n\t\t\t\t\tmargin-bottom: 5px;\n\t\t\t\t}\n\t\t\t\t.amount-value {\n\t\t\t\t\tfont-size: 32px;\n\t\t\t\t\tfont-weight: bold;\n\t\t\t\t\tcolor: #2e7d32;\n\t\t\t\t}\n\t\t\t\t.footer {\n\t\t\t\t\ttext-align: center;\n\t\t\t\t\tmargin-top: 30px;\n\t\t\t\t\tpadding-top: 20px;\n\t\t\t\t\tborder-top: 1px solid #eee;\n\t\t\t\t\tfont-size: 12px;\n\t\t\t\t\tcolor: #7f8c8d;\n\t\t\t\t}\n\t\t\t\t.transaction-id {\n\t\t\t\t\tbackground-color: #f1f1f1;\n\t\t\t\t\tpadding: 10px;\n\t\t\t\t\tborder-radius: 4px;\n\t\t\t\t\tfont-family: monospace;\n\t\t\t\t\tfont-size: 12px;\n\t\t\t\t\ttext-align: center;\n\t\t\t\t\tmargin: 20px 0;\n\t\t\t\t}\n\t\t\t</style>\n\t\t</head>\n\t\t<body>\n\t\t\t<div class=\"receipt-container\">\n\t\t\t\t<div class=\"header\">\n\t\t\t\t\t<div class=\"logo\">CityWay</div>\n\t\t\t\t\t<div class=\"receipt-title\">Wallet Top-up Receipt</div>\n\t\t\t\t\t<div class=\"receipt-subtitle\">Transaction Successful</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"amount-section\">\n\t\t\t\t\t<div class=\"amount-label\">Amount Added</div>\n\t\t\t\t\t<div class=\"amount-value\">₦8,649.09</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"details-section\">\n\t\t\t\t\t<div class=\"detail-row\">\n\t\t\t\t\t\t<span class=\"detail-label\">Date</span>\n\t\t\t\t\t\t<span class=\"detail-value\">26 April 2025</span>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"detail-row\">\n\t\t\t\t\t\t<span class=\"detail-label\">Time</span>\n\t\t\t\t\t\t<span class=\"detail-value\">05:11 am</span>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"transaction-id\">\n\t\t\t\t\tTransaction ID: 830650423\n\t\t\t\t</div>\n\n\t\t\t\t<div class=\"footer\">\n\t\t\t\t\t<p>Thank you for using CityWay</p>\n\t\t\t\t\t<p>This is an automated receipt. Please do not reply to this email.</p>\n\t\t\t\t\t<p>If you have any questions, please contact our support team.</p>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</body>\n\t\t</html>\n\t"}
