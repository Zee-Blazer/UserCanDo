{"to":"cf.youvarsity+2@gmail.com","subject":"Order delivered","html":"\n    <!DOCTYPE html>\n    <html>\n      <head>\n        <meta charset=\"utf-8\">\n        <title>Order Delivered - Cityway</title>\n        <style>\n          body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            color: #333;\n            max-width: 600px;\n            margin: 0 auto;\n            padding: 20px;\n          }\n          .header {\n            text-align: center;\n            padding: 20px 0;\n            background-color: #f8f9fa;\n            border-radius: 5px;\n          }\n          .logo {\n            max-width: 150px;\n            margin-bottom: 20px;\n          }\n          .content {\n            padding: 20px;\n            background-color: #fff;\n            border-radius: 5px;\n            margin-top: 20px;\n          }\n          .button {\n            display: inline-block;\n            padding: 10px 20px;\n            background-color: #500707;\n            color: white;\n            text-decoration: none;\n            border-radius: 5px;\n            margin-top: 20px;\n          }\n          .footer {\n            text-align: center;\n            margin-top: 30px;\n            font-size: 12px;\n            color: #666;\n          }\n          .order-details {\n            background-color: #f8f9fa;\n            padding: 15px;\n            border-radius: 5px;\n            margin: 15px 0;\n            border: 1px solid #ddd;\n          }\n          .success-badge {\n            display: inline-block;\n            padding: 5px 10px;\n            background-color: #4CAF50;\n            color: white;\n            border-radius: 15px;\n            font-size: 14px;\n            margin: 5px 0;\n          }\n        </style>\n      </head>\n      <body>\n        <div class=\"header\">\n          <img src=\"https://cityway-food.vercel.app/assets/citywaytext-Dx3NTNjd.png\" alt=\"Cityway Logo\" class=\"logo\">\n          <h1>Order Delivered Successfully! 🎉</h1>\n        </div>\n        \n        <div class=\"content\">\n          <p>Hello Robinson Chosen,</p>\n          \n          <p>Great news! Your order #6807c854fa814153a731c198 has been successfully delivered.</p>\n          \n          <div class=\"order-details\">\n            <p><strong>Order Details:</strong></p>\n            <ul>\n              <li>Order Number: 6807c854fa814153a731c198</li>\n              <li>Delivery Time: 4/28/2025, 11:06:48 AM</li>\n              <li>Total Amount: ₦27,893.72</li>\n              <li>Delivery Address: 6F92+R93, Kongo, Ìpínlẹ̀ Ògùn</li>\n            </ul>\n          </div>\n\n          <p style=\"text-align: center;\">\n            <span class=\"success-badge\">Order Completed</span>\n          </p>\n          \n          <p>We hope you enjoyed your order! If you have a moment, we'd love to hear about your experience.</p>\n          \n          <p>Thank you for choosing Cityway for your delivery needs. We look forward to serving you again!</p>\n          \n          <p>If you have any questions or need assistance, please don't hesitate to contact our support team.</p>\n        </div>\n        \n        <div class=\"footer\">\n          <p>This is an automated message. Please do not reply to this email.</p>\n          <p>© 2025 Cityway. All rights reserved.</p>\n        </div>\n      </body>\n    </html>\n  "}
