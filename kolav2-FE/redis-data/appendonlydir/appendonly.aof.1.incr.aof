{"to":["cf.youvarsity+2@gmail.com","patiencesimoniseoluwa+1@gmail.com"],"subject":"New Order Available for Pickup!","html":"\n    <!DOCTYPE html>\n    <html>\n      <head>\n        <meta charset=\"utf-8\">\n        <title>New Order Available for Pickup</title>\n        <style>\n          body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            color: #333;\n            max-width: 600px;\n            margin: 0 auto;\n            padding: 20px;\n          }\n          .header {\n            background-color: #500707;\n            color: white;\n            padding: 20px;\n            text-align: center;\n            border-radius: 5px;\n          }\n          .content {\n            padding: 20px;\n            background-color: #f9f9f9;\n            border-radius: 5px;\n            margin-top: 20px;\n          }\n          .button {\n            display: inline-block;\n            padding: 10px 20px;\n            background-color: #500707;\n            color: white;\n            text-decoration: none;\n            border-radius: 5px;\n            margin-top: 20px;\n          }\n          .footer {\n            text-align: center;\n            margin-top: 20px;\n            font-size: 12px;\n            color: #666;\n          }\n          .order-details {\n            background-color: white;\n            padding: 15px;\n            border-radius: 5px;\n            margin: 15px 0;\n            border: 1px solid #ddd;\n          }\n          .highlight {\n            color: #500707;\n            font-weight: bold;\n          }\n        </style>\n      </head>\n      <body>\n        <div class=\"header\">\n          <h1>New Order Available for Pickup!</h1>\n        </div>\n        \n        <div class=\"content\">\n          <p>Hello Rider,</p>\n          \n          <p>A new order is available for pickup. Here are the order details:</p>\n          \n          <div class=\"order-details\">\n            <p><strong>Order ID:</strong> 681c9f53c8413a4524f10e0a</p>\n            <p><strong>Pickup Location:</strong> Chosen Foundation</p>\n            <p><strong>Delivery Address:</strong> Iwo-Road Flyover, Ibadan, Nigeria</p>\n            <p><strong>Distance:</strong> 7.2 km km</p>\n            <p><strong>Estimated Duration:</strong> 16 mins minutes</p>\n            <p><strong>Delivery Fee:</strong> ₦2,322.32</p>\n          </div>\n          \n          <p>Open your app and accept the order if you're available for delivery.</p>\n          \n       \n          \n          <p style=\"margin-top: 20px; font-size: 14px; color: #666;\">\n            <strong>Note:</strong> Orders are assigned on a first-come, first-served basis. \n            Please accept the order only if you can complete the delivery.\n          </p>\n        </div>\n        \n        <div class=\"footer\">\n          <p>This is an automated message. Please do not reply to this email.</p>\n          <p>© 2025 CityWay. All rights reserved.</p>\n        </div>\n      </body>\n    </html>\n  "}
