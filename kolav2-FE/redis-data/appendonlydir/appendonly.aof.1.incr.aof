{"to":"cf.youvarsity+1@gmail.com","subject":"Order confirmed","html":"\n    <!DOCTYPE html>\n    <html>\n      <head>\n        <meta charset=\"utf-8\">\n        <title>Order Confirmation</title>\n        <style>\n          body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            color: #333;\n            max-width: 600px;\n            margin: 0 auto;\n            padding: 20px;\n          }\n          .header {\n            background-color: #500707;\n            color: white;\n            padding: 20px;\n            text-align: center;\n            border-radius: 5px;\n          }\n          .content {\n            padding: 20px;\n            background-color: #f9f9f9;\n            border-radius: 5px;\n            margin-top: 20px;\n          }\n          .order-details {\n            background-color: white;\n            padding: 15px;\n            border-radius: 5px;\n            margin: 15px 0;\n            border: 1px solid #ddd;\n          }\n          .status-badge {\n            display: inline-block;\n            padding: 5px 10px;\n            background-color: #500707;\n            color: white;\n            border-radius: 15px;\n            font-size: 14px;\n            margin: 5px 0;\n          }\n          .button {\n            display: inline-block;\n            padding: 10px 20px;\n            background-color: #500707;\n            color: white;\n            text-decoration: none;\n            border-radius: 5px;\n            margin-top: 20px;\n          }\n          .footer {\n            text-align: center;\n            margin-top: 20px;\n            font-size: 12px;\n            color: #666;\n          }\n          .timeline {\n            margin: 20px 0;\n            padding: 0;\n            list-style: none;\n          }\n          .timeline-item {\n            position: relative;\n            padding-left: 30px;\n            margin-bottom: 15px;\n          }\n          .timeline-item:before {\n            content: \"✓\";\n            position: absolute;\n            left: 0;\n            color: #4CAF50;\n            font-weight: bold;\n          }\n        </style>\n      </head>\n      <body>\n        <div class=\"header\">\n          <h1>Order Confirmed!</h1>\n        </div>\n        \n        <div class=\"content\">\n          <p>Hello,</p>\n          \n          <p>Your order has been confirmed and is now being processed. Here are the details:</p>\n          \n          <div class=\"order-details\">\n            <p><strong>Order ID:</strong> 681c9f53c8413a4524f10e0a</p>\n            <p><strong>Status:</strong> <span class=\"status-badge\">Processing</span></p>\n            <p><strong>Order Date:</strong> 5/8/2025, 1:10:59 PM</p>\n            <p><strong>Delivery Address:</strong> Iwo-Road Flyover, Ibadan, Nigeria</p>\n            <p><strong>Total Amount:</strong> ₦40,072.32</p>\n          </div>\n\n          <h3>What's Next?</h3>\n          <ul class=\"timeline\">\n            <li class=\"timeline-item\">Order received and confirmed</li>\n            <li class=\"timeline-item\">Preparing your order</li>\n            <li class=\"timeline-item\">Assigning a rider</li>\n            <li class=\"timeline-item\">On the way to you</li>\n          </ul>\n          \n          <p>You can track your order status by clicking on the order in your app</p>\n          \n          <p style=\"margin-top: 20px; font-size: 14px; color: #666;\">\n            <strong>Note:</strong> If you have any questions about your order, please contact our support team.\n          </p>\n        </div>\n        \n        <div class=\"footer\">\n          <p>This is an automated message. Please do not reply to this email.</p>\n          <p>© 2025 CityWay. All rights reserved.</p>\n        </div>\n      </body>\n    </html>\n  "}
